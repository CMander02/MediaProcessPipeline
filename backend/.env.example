# Media Process Pipeline Configuration

# Debug mode
DEBUG=false

# AI Provider API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# HuggingFace token (required for Pyannote diarization)
HF_TOKEN=

# WhisperX settings
WHISPER_MODEL=large-v3-turbo
# 本地 Whisper 模型路径，留空则自动下载
# 例如: D:/models/whisper-large-v3 或 HuggingFace 缓存路径
WHISPER_MODEL_PATH=
COMPUTE_TYPE=float16
DEVICE=cuda

# Pyannote/Diarization settings (需要 HF_TOKEN 或指定本地路径)
# 本地 pyannote speaker-diarization 模型路径
PYANNOTE_MODEL_PATH=
# 本地 pyannote segmentation 模型路径
PYANNOTE_SEGMENTATION_PATH=

# wav2vec2 alignment model paths (WhisperX 对齐用)
# 中文: jonatasgrosman/wav2vec2-large-xlsr-53-chinese-zh-cn
ALIGNMENT_MODEL_ZH=
# 英文: 留空使用 torchaudio 内置
ALIGNMENT_MODEL_EN=

# UVR settings
# 默认使用 UVR-MDX-NET-Inst_HQ_3 (本地 UVR 安装已有)
UVR_MODEL=UVR-MDX-NET-Inst_HQ_3
# UVR 模型目录路径
# Windows 默认路径: C:/Users/<用户名>/AppData/Local/Programs/Ultimate Vocal Remover/models
UVR_MODEL_DIR=
# 具体 UVR 模型文件路径（可选，优先于 UVR_MODEL_DIR）
UVR_MDX_INST_HQ3_PATH=
UVR_HP_UVR_PATH=
UVR_DENOISE_LITE_PATH=
UVR_KIM_VOCAL_2_PATH=
UVR_DEECHO_DEREVERB_PATH=
UVR_HTDEMUCS_PATH=

# Bilibili settings (optional)
# SESSDATA cookie for higher quality downloads (requires login)
# Get it from browser DevTools > Application > Cookies > bilibili.com > SESSDATA
BILIBILI_SESSDATA=

# Data directories (relative to backend/)
DATA_INBOX=../data/inbox
DATA_PROCESSING=../data/processing
DATA_OUTPUTS=../data/outputs
DATA_ARCHIVE=../data/archive

# Obsidian vault path (optional)
OBSIDIAN_VAULT_PATH=
